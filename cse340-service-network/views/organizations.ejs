```ejs
<%- include("partials/header", { title: title }) %>

    <main class="container">

        <h1>
            <%= title %>
        </h1>

        <section class="organizations">

            <img src="/images/organization.jpg" alt="Community organization" class="hero-image">

            <% organizations.forEach(org=> { %>

                <div class="card">

                    <img src="<%= org.logo %>" alt="<%= org.organization_name %> logo">

                    <h2>
                        <%= org.organization_name %>
                    </h2>

                    <p>
                        <%= org.description %>
                    </p>

                    <p>
                        Email:
                        <%= org.contact_email %>
                    </p>

                </div>

                <% }) %>

        </section>

    </main>

    <%- include("partials/footer") %>