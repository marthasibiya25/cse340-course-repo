<%- include("partials/header", { title: title }) %>

    <main class="container">

        <section class="hero">
            <img src="" alt="Community volunteers" class="hero-image">
            <h1>
                <%= title %>
            </h1>

            <p>
                Welcome to Service Network, a platform that connects
                volunteers, organizations, and community projects.
            </p>

            <p>
                Discover opportunities to serve, collaborate, and create
                a positive impact in your community.
            </p>
        </section>

        <section class="featured">
            <h2>What We Offer</h2>

            <div class="cards">
                <div class="card">
